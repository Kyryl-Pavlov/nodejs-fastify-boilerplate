{
  "name": "nodejs-fastify-boilerplate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A production-ready Node.js / Fastify boilerplate for building scalable REST and GraphQL APIs.",
  "license": "MIT",
  "workspaces": [
    "services/app",
    "lambda"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run tests/app/unit tests/app/integration",
    "test:unit": "vitest run tests/app/unit",
    "test:integration": "vitest run tests/app/integration",
    "test:e2e": "vitest run tests/app/e2e",
    "test:coverage": "vitest run tests/app/unit tests/app/integration --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^22.10.2",
    "globals": "^15.14.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "form-data": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  }
}
